{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.type1skills.com/schemas/ideas-radar.snapshot.schema.json",
  "title": "Type1Skills Ideas Radar Snapshot",
  "type": "object",
  "required": [
    "generatedAt",
    "summary",
    "lanes"
  ],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "required": [
        "accepted",
        "incubating",
        "inbox",
        "rejected"
      ],
      "properties": {
        "accepted": { "type": "integer", "minimum": 0 },
        "incubating": { "type": "integer", "minimum": 0 },
        "inbox": { "type": "integer", "minimum": 0 },
        "rejected": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "lanes": {
      "type": "object",
      "properties": {
        "accepted": { "type": "array", "items": { "$ref": "#/$defs/idea" } },
        "incubating": { "type": "array", "items": { "$ref": "#/$defs/idea" } },
        "inbox": { "type": "array", "items": { "$ref": "#/$defs/idea" } },
        "rejected": { "type": "array", "items": { "$ref": "#/$defs/idea" } }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "idea": {
      "type": "object",
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "docPath": { "type": "string" },
        "nextAction": { "type": "string" },
        "todoRefs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
